# Production Environment Variables
# Copy this file to .env and update values

# Domain Configuration
DOMAIN=links.yourdomain.com

# Database Configuration (Required)
POSTGRES_PASSWORD=change_this_to_secure_random_password

# GitHub Integration (Optional)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Sync Settings
SYNC_INTERVAL_MINUTES=30

# Application Settings
NODE_ENV=production
PORT=3000

# API Authentication (REQUIRED for all non-health endpoints)
# Generate with: openssl rand -hex 32
# Must match between backend (LINK_MANAGER_API_KEY) and frontend (VITE_API_KEY)
LINK_MANAGER_API_KEY=replace-with-256-bit-random
VITE_API_KEY=replace-with-256-bit-random
